{
  "name": "effect-line-manager",
  "version": "0.2.2",
  "description": "Headless Effect library for managing LINE Messaging API channels and clients.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./adapter": "./dist/adapter/index.mjs",
    "./httpapi": "./dist/httpapi/index.mjs",
    "./login": "./dist/login/index.mjs",
    "./messaging": "./dist/messaging/index.mjs",
    "./registry": "./dist/registry/index.mjs",
    "./web": "./dist/web/index.mjs",
    "./web/developers-console": "./dist/web/developers-console/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "dev:consumer": "node scripts/sync-dev-package.mjs && vp pack --watch",
    "dev:demo": "vp dev demo",
    "test": "vp test",
    "check": "vp check && vpx tsgo --noEmit",
    "prepublishOnly": "vp run build",
    "prepare": "vp config && effect-tsgo patch",
    "changeset": "changeset",
    "version": "changeset version && node scripts/sync-jsr.js",
    "release": "vp pack && vpx jsr publish --allow-slow-types"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "^0.86.2",
    "@effect/platform-node": "4.0.0-beta.78",
    "@effect/tsgo": "0.14.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "effect": "4.0.0-beta.78",
    "express": "^4.22.2",
    "express5": "npm:express@^5.2.1",
    "happy-dom": "^20.10.2",
    "hono": "^4.12.25",
    "lit": "^3.3.3",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.78",
    "lit": "^3.3.3"
  },
  "peerDependenciesMeta": {
    "lit": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.5.2"
}
